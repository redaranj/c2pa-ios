// CI Configuration for automated testing and builds
#include "Base.xcconfig"

// CI-specific settings
GCC_OPTIMIZATION_LEVEL = 0
ENABLE_TESTABILITY = YES
ONLY_ACTIVE_ARCH = NO  // Build for all architectures in CI

// Swift CI Settings
SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) CI TESTING
SWIFT_OPTIMIZATION_LEVEL = -Onone
OTHER_SWIFT_FLAGS = $(inherited) -D CI -D TESTING -enable-testing -warnings-as-errors

// Sanitizers
CLANG_ADDRESS_SANITIZER = YES
CLANG_ADDRESS_SANITIZER_CONTAINER_OVERFLOW = YES
CLANG_THREAD_SANITIZER = NO  // Incompatible with Address Sanitizer
CLANG_UNDEFINED_BEHAVIOR_SANITIZER = YES
CLANG_UNDEFINED_BEHAVIOR_SANITIZER_INTEGER = YES
CLANG_UNDEFINED_BEHAVIOR_SANITIZER_NULLABILITY = YES

// Static Analysis
RUN_CLANG_STATIC_ANALYZER = YES
CLANG_STATIC_ANALYZER_MODE = deep
CLANG_ANALYZER_SECURITY_FLOATLOOPCOUNTER = YES
CLANG_ANALYZER_SECURITY_INSECUREAPI_RAND = YES
CLANG_ANALYZER_SECURITY_INSECUREAPI_STRCPY = YES

// Code Coverage
CLANG_ENABLE_CODE_COVERAGE = YES
GCC_INSTRUMENT_PROGRAM_FLOW_ARCS = YES
GCC_GENERATE_TEST_COVERAGE_FILES = YES

// Warnings
GCC_WARN_ABOUT_RETURN_TYPE = YES_ERROR
GCC_WARN_UNDECLARED_SELECTOR = YES
GCC_WARN_UNINITIALIZED_AUTOS = YES_AGGRESSIVE
GCC_WARN_UNUSED_FUNCTION = YES
GCC_WARN_UNUSED_VARIABLE = YES
CLANG_WARN_SUSPICIOUS_MOVE = YES
CLANG_WARN_UNREACHABLE_CODE = YES
CLANG_WARN_DOCUMENTATION_COMMENTS = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = YES

// CI Environment Variables
CI = true
CONTINUOUS_INTEGRATION = true

// Timeout Settings
TEST_EXECUTION_TIME_ALLOWANCE = 60
MAXIMUM_TEST_EXECUTION_TIME_ALLOWANCE = 300

// Parallel Testing
PARALLEL_TESTING_ENABLED = YES
PARALLEL_TESTING_WORKER_COUNT = 4